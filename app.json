{
  "expo": {
    "name": "CAIR",
    "slug": "cair-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a4731"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ar.cair.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "CAIR necesita acceso a la cámara para subir fotos de campos.",
        "NSPhotoLibraryUsageDescription": "CAIR necesita acceso a tu galería para subir fotos de campos.",
        "NSLocationWhenInUseUsageDescription": "CAIR usa tu ubicación para mostrarte campos cercanos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a4731"
      },
      "package": "ar.cair.mobile",
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "TU_GOOGLE_MAPS_API_KEY"
        }
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "cair",
    "extra": {
      "apiUrl": "http://localhost:3000",
      "router": {},
      "eas": {
        "projectId": "2e997574-ef56-45b2-8fea-dd344ddc50f2"
      }
    }
  }
}
